rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read, write: if isOwner(userId);
      
      // Circuits subcollection
      match /circuits/{circuitId} {
        // Users can read their own circuits, or anyone can read if it's public
        allow read: if isOwner(userId) || resource.data.isPublic == true;
        // Only the owner can create, update, or delete
        allow write: if isOwner(userId);
      }
    }

    // Public circuits collection
    match /publicCircuits/{circuitId} {
      // Anyone can read public circuits
      allow read: if true;
      
      // Only authenticated users can create public circuits, and the uid must match
      allow create: if isAuthenticated() && 
                    request.resource.data.uid == request.auth.uid;
                    
      // Only the owner can update or delete their public circuits
      allow update: if isAuthenticated() && 
                    resource.data.uid == request.auth.uid &&
                    request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && 
                    resource.data.uid == request.auth.uid;
    }
  }
}
